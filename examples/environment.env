# Configuration template for the ONDEWO Survey NodeJS client examples.
#
# This is a NON-SECRET template: it ships placeholders only, never real credentials.
# Copy it, fill in your own values, and keep secrets out of version control.
# Each example loads this file via dotenv (path resolved relative to the script).

# --- Connection (gRPC endpoint of the Survey server) ---
ONDEWO_HOST=localhost
ONDEWO_PORT=50055

# --- Secure channel ---
# ONDEWO_USE_SECURE_CHANNEL=true uses TLS; set to false for a local plaintext server.
ONDEWO_USE_SECURE_CHANNEL=true
# Optional path to a root CA certificate file for the TLS channel (leave blank to use system roots).
ONDEWO_GRPC_CERT=

# --- Keycloak (D18 headless-SDK offline-token login) ---
KEYCLOAK_URL=https://auth.ondewo.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-survey-cai-sdk-public
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Set to false to skip TLS certificate verification on the Keycloak token request (self-signed local Envoy).
KEYCLOAK_VERIFY_SSL=true

# --- Survey-service-specific ---
# List page token passed to ListSurveys (empty requests the first page).
ONDEWO_SURVEY_PAGE_TOKEN=page_size-10000
